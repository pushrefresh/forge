# Copy this to `.env` (committed-convention defaults) or `.env.local`
# (your personal overrides — wins over `.env`). Both files are gitignored.
# Shell env vars override both files.
#
# Forge picks the active provider based on which key is present on first
# launch; after that, switch providers from Settings. With no keys set,
# Forge uses a deterministic mock provider so demos work offline.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional — override the default model id. Leave blank to use a sensible
# default per provider (claude-sonnet-4-6 / gpt-5 / anthropic/claude-sonnet-4-6).
FORGE_MODEL=

# --- Release / build (only needed when running `npm run release`) -----------

# Sentry DSN (public write-only identifier, safe to ship in builds).
FORGE_SENTRY_DSN=

# macOS code signing + notarization. TEAM_ID is the 10-char code at the
# end of `security find-identity -v -p codesigning`. APP_SPECIFIC_PASSWORD
# is generated at appleid.apple.com (NOT your Apple ID login password).
APPLE_TEAM_ID=
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=

# GitHub token for publishing releases to pushrefresh/forge. Grab via
# `gh auth token`. Needs `repo` scope.
GH_TOKEN=
