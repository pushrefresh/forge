# Copy this to `.env` (committed-convention defaults) or `.env.local`
# (your personal overrides — wins over `.env`). Both files are gitignored.
# Shell env vars override both files.
#
# Forge picks the active provider based on which key is present on first
# launch; after that, switch providers from Settings. With no keys set,
# Forge uses a deterministic mock provider so demos work offline.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional — override the default model id. Leave blank to use a sensible
# default per provider (claude-sonnet-4-6 / gpt-5 / anthropic/claude-sonnet-4-6).
FORGE_MODEL=
